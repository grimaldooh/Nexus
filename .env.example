# Azure SQL Database Connection
DATABASE_CONNECTION_STRING=Server=tcp:YOUR_SERVER.database.windows.net,1433;Database=YourDbName;User ID=YourUser;Password=YourPassword;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Connection Timeout=60;

# API Security
API_KEY=your-secret-api-key-here

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-openai-key-here
